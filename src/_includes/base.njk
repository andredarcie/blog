<!DOCTYPE html>
<html lang="{{ 'en' if lang == 'en' else 'pt-BR' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — André N. Darcie</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  {% if lang == "en" %}
    <link rel="alternate" type="application/atom+xml" title="André N. Darcie (English)" href="https://andrendarcie.github.io/blog/en/feed.xml" />
  {% else %}
    <link rel="alternate" type="application/atom+xml" title="André N. Darcie" href="https://andrendarcie.github.io/blog/feed.xml" />
  {% endif %}
</head>
<body>
  <header>
    <nav>
      {% if lang == "en" %}
        <a href="{{ '/en/' | url }}" class="site-title">André N. Darcie</a>
        <a href="{{ '/en/about/' | url }}">About</a>
      {% else %}
        <a href="{{ '/' | url }}" class="site-title">André N. Darcie</a>
        <a href="{{ '/sobre/' | url }}">Sobre</a>
      {% endif %}

      {% if translationKey %}
        {% set tEntry = collections.translationMap[translationKey] %}
        {% if lang == "en" and tEntry and tEntry.pt %}
          <a href="{{ tEntry.pt | url }}" class="lang-switch">Português</a>
        {% elif lang != "en" and tEntry and tEntry.en %}
          <a href="{{ tEntry.en | url }}" class="lang-switch">English</a>
        {% endif %}
      {% elif translationUrl %}
        {% if lang == "en" %}
          <a href="{{ translationUrl | url }}" class="lang-switch">Português</a>
        {% else %}
          <a href="{{ translationUrl | url }}" class="lang-switch">English</a>
        {% endif %}
      {% endif %}
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; 2026 André N. Darcie</p>
  </footer>
  <script>
    if ('speechSynthesis' in window) {
      window.addEventListener('pageshow', function () {
        window.speechSynthesis.cancel();
      });
    }
  </script>
</body>
</html>
